# ---------------------------------------------------------------------------
# Environment template — copy to `.env.local` (or `.env`) and fill in real values.
# NEVER commit real secrets; only this placeholder template is tracked in git.
# ---------------------------------------------------------------------------

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# NextAuth
AUTH_SECRET="generate-a-long-random-secret"
AUTH_URL="http://localhost:3000"

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Email (Nodemailer / SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-user"
SMTP_PASSWORD="your-smtp-password"
EMAIL_FROM="noreply@example.com"

# Site
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# PayPal (Bookstore) — create a REST app at https://developer.paypal.com
# Funds settle to your PayPal business account. Use "sandbox" while testing,
# switch to "live" for production.
# ---------------------------------------------------------------------------
PAYPAL_ENV="sandbox"
PAYPAL_CLIENT_ID="your-paypal-rest-client-id"
PAYPAL_CLIENT_SECRET="your-paypal-rest-secret"
# Webhook id from the PayPal app's webhook (points to /api/store/paypal/webhook)
PAYPAL_WEBHOOK_ID="your-paypal-webhook-id"
# Client-side SDK id (safe to expose). Usually the same value as PAYPAL_CLIENT_ID.
NEXT_PUBLIC_PAYPAL_CLIENT_ID="your-paypal-rest-client-id"

# ---------------------------------------------------------------------------
# AI enrichment (Bookstore) — drafts book descriptions & key insights.
# Optional: if unset, uploads still parse metadata; you just write copy yourself.
# ---------------------------------------------------------------------------
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"
